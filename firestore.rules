rules_version = '2';

// ChildTime — family data separation.
//
// A child belongs to a HOUSEHOLD; a parent may access a child only if their uid
// is on that child's household. Reads use `resource` (the existing doc); writes
// that set/replace data use `request.resource`. Mixing them up (e.g. reading
// request.resource on a read) silently denies everything — which is the bug this
// version fixes.
//
// Deploy:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    function householdHasMe(hid) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(hid))
        && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.parentUIDs;
    }

    // Parent account — only the owner.
    match /parents/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Households.
    match /households/{hid} {
      allow read:   if signedIn() && request.auth.uid in resource.data.parentUIDs;
      allow create: if signedIn() && request.auth.uid in request.resource.data.parentUIDs;
      // Members can update; a non-member may join by adding ONLY their own uid.
      allow update: if signedIn() && (
        request.auth.uid in resource.data.parentUIDs ||
        request.resource.data.parentUIDs.hasOnly(resource.data.parentUIDs.concat([request.auth.uid]))
      );
      allow delete: if signedIn() && request.auth.uid in resource.data.parentUIDs;
    }

    // Children — gated on the household. Reads/updates/deletes use the EXISTING
    // doc's householdID; creates use the incoming data's householdID.
    match /children/{childID} {
      allow read:   if householdHasMe(resource.data.householdID);
      allow create: if householdHasMe(request.resource.data.householdID);
      allow update: if householdHasMe(resource.data.householdID)
                    && householdHasMe(request.resource.data.householdID);
      allow delete: if householdHasMe(resource.data.householdID);

      // state/current, dailyStats/*, events/* — gated on the parent child's household.
      match /{sub=**} {
        allow read, write: if signedIn() &&
          householdHasMe(get(/databases/$(database)/documents/children/$(childID)).data.householdID);
      }
    }

    // Legacy per-user progress path (older builds wrote here). Owner-only.
    match /users/{uid}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Invites — readable by any signed-in user (to redeem by code), creatable by
    // the household owner, updatable to stamp redeemedBy.
    match /invites/{code} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.createdBy;
      allow update: if signedIn();
    }

    // Child-link requests — a parent asks to absorb a child who registered with
    // their own email; the child approves on their device. Visible only to the
    // requesting parent and to the account whose email is targeted.
    match /childLinkRequests/{id} {
      allow create: if signedIn() && request.auth.uid == request.resource.data.fromParentUID;
      allow read:   if signedIn() && (
        request.auth.uid == resource.data.fromParentUID ||
        request.auth.token.email.lower() == resource.data.toEmail
      );
      // Only the targeted child can change the status (approve / decline).
      allow update: if signedIn() && request.auth.token.email.lower() == resource.data.toEmail;
      // The requesting parent may delete their own requests (cleanup / resend).
      allow delete: if signedIn() && request.auth.uid == resource.data.fromParentUID;
    }

    // Weekly reports — readable by the child's household parents (written by
    // Cloud Functions with admin privileges, which bypass these rules).
    match /weeklyReports/{childID}/{rest=**} {
      allow read: if signedIn() &&
        householdHasMe(get(/databases/$(database)/documents/children/$(childID)).data.householdID);
    }
  }
}
